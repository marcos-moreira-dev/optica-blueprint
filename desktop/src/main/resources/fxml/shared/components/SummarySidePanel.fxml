<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.marcosmoreira.opticademo.shared.ui.components.SummarySidePanelController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
    <VBox fx:id="contentBox" spacing="8">
        <Label fx:id="panelTitleLabel" text="Resumen" styleClass="summary-panel-title"/>
        <VBox fx:id="fieldsContainer" spacing="4"/>
        <HBox fx:id="actionsContainer" spacing="8" styleClass="summary-actions"/>
    </VBox>
</ScrollPane>
