<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<HBox fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.marcosmoreira.opticademo.shared.ui.components.PaginationBarController"
      alignment="CENTER_LEFT" spacing="16">
    <padding>
        <Insets top="8" right="8" bottom="8" left="8"/>
    </padding>
    <Label fx:id="recordsLabel" text="Mostrando 0 de 0 registros" styleClass="pagination-records"/>
    <Label fx:id="pageLabel" text="Pagina 1 de 1" styleClass="pagination-page"/>
    <HBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS"/>
    <Button fx:id="prevButton" text="Anterior" styleClass="pagination-btn"/>
    <Button fx:id="nextButton" text="Siguiente" styleClass="pagination-btn"/>
</HBox>
