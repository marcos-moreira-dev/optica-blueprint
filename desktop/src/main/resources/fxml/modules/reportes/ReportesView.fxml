                <VBox spacing="16" style="-fx-padding: 12;">

                    <!-- Identidad del indicador -->
                    <VBox spacing="4" styleClass="summary-section">
                        <Label text="Identidad del indicador" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -optica-text-secondary;"/>
                        <Label fx:id="summaryIndicador" text="Ventas del periodo" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label fx:id="summaryCategoria" text="General" styleClass="summary-field-label"/>
                            <Label text="|" style="-fx-text-fill: -optica-border;"/>
                            <Label fx:id="summarySucursal" text="Todas" styleClass="summary-field-label"/>
                        </HBox>
                    </VBox>

                    <!-- Valor actual -->
                    <VBox spacing="4" styleClass="summary-section">
                        <Label text="Valor actual" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -optica-text-secondary;"/>
                        <Label fx:id="summaryValorPrincipal" text="8,420" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: -optica-primary;"/>
                        <Label fx:id="summaryVariacionBreve" text="+12% vs periodo anterior" styleClass="summary-field-label"/>
                    </VBox>

                    <!-- Contexto temporal -->
                    <VBox spacing="4" styleClass="summary-section">
                        <Label text="Contexto temporal" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -optica-text-secondary;"/>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <VBox spacing="2">
                                <Label text="Periodo" styleClass="summary-field-label"/>
                                <Label fx:id="summaryPeriodo" text="Abril 2026" style="-fx-font-size: 13px;"/>
                            </VBox>
                            <VBox spacing="2">
                                <Label text="Ultima actualizacion" styleClass="summary-field-label"/>
                                <Label fx:id="summaryUltimaActualizacion" text="16/04/2026 14:30" style="-fx-font-size: 13px;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Lectura rapida -->
                    <VBox spacing="4" styleClass="summary-section">
                        <Label text="Lectura rapida" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -optica-text-secondary;"/>
                        <Label fx:id="summaryObservacionGerencial" text="Ventas por encima de la meta mensual" wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: -optica-text-secondary;"/>
                    </VBox>

                    <!-- Acciones rapidas -->
                    <VBox spacing="4" styleClass="summary-section">
                        <Label text="Accion sugerida" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -optica-text-secondary;"/>
                        <Label fx:id="summaryAccionSugerida" text="Mantener promocion de monturas hasta fin de mes" wrapText="true" style="-fx-font-size: 13px;"/>
                        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 8 0 0 0;">
                            <Button fx:id="summaryBtnGenerar" text="Generar" styleClass="btn-primary"/>
                            <Button fx:id="summaryBtnExportar" text="Exportar" styleClass="btn-secondary"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
            </VBox>

        </VBox>
    </center>

</BorderPane>
